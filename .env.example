# Copy to .env (gitignored) for local LIVE runs, or set as GitHub Actions secrets.
# Everything works with NO keys: ESPN (scores/fields) and Open-Meteo (weather) are
# free and keyless. The only optional key is The Odds API free tier, used to pull
# any available FanDuel round props.

# The Odds API free-tier key (optional)
ODDS_API_KEY=
