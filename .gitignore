# Dependencies
node_modules/

# Build output (published to GitHub Pages by CI, never committed)
dist/

# Environment
.env
.env.local

# Logs
*.log

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Playwright artifacts (screenshots in tests/visual/__shots__ ARE committed)
test-results/
playwright-report/

# Local dev-only screenshot harness (not product code)
/capture-tmp.mjs
/diag-tmp.mjs
/pcap-tmp.mjs

# Firebase CLI cache (functions deploys — docs/16_PAYMENTS.md)
.firebase/

# Raw Sketchfab source packs (huge; only the converted assets/models/nature
