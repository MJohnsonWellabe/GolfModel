{
  "name": "bite-sized-golf",
  "version": "1.0.0",
  "description": "Johnson's Golf — mobile browser golf game (Babylon.js 3D + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:fast": "vitest run --exclude tests/simulation/scoring.test.ts --exclude tests/simulation/newCourses.test.ts --exclude tests/simulation/aiTournament.test.ts",
    "test:sim": "vitest run tests/simulation/scoring.test.ts tests/simulation/newCourses.test.ts tests/simulation/aiTournament.test.ts",
    "shots": "playwright test -c playwright.config.ts",
    "shots:ci": "playwright test -c playwright.config.ts tests/visual/perf.spec.ts tests/visual/gameplay.spec.ts tests/visual/courses.spec.ts tests/visual/occlusion.spec.ts",
    "portraits": "node scripts/gen-portraits.mjs",
    "pal-portraits": "node scripts/gen-pal-portraits.mjs",
    "convert:nature": "node scripts/convert-nature.mjs",
    "convert:pals": "node scripts/convert-pals.mjs",
    "convert:sand": "node scripts/convert-sand-texture.mjs",
    "convert:turf": "node scripts/convert-turf-texture.mjs",
    "audit:assets": "node scripts/audit-assets.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^9.15.0",
    "@babylonjs/loaders": "^9.15.0",
    "earcut": "^3.2.3",
    "firebase": "^12.15.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "fbx2gltf": "^0.9.7-p1",
    "meshoptimizer": "^1.2.0",
    "sharp": "^0.34.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^4.1.10"
  }
}
