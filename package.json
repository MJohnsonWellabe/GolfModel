{
  "name": "johnsons-golf",
  "version": "1.0.0",
  "description": "Johnson's Golf — mobile browser golf game (Babylon.js 3D + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "shots": "playwright test -c playwright.config.ts",
    "portraits": "node scripts/gen-portraits.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^9.15.0",
    "@babylonjs/loaders": "^9.15.0",
    "firebase": "^12.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "fbx2gltf": "^0.9.7-p1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^4.1.10"
  }
}
